# -------------------------------
# Banco de dados
# -------------------------------
POSTGRES_DB=inovareti
POSTGRES_USER=inovareti_user
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -------------------------------
# Segurança e criptografia
# -------------------------------
# Substitua por uma string segura em produção (mínimo 32+ caracteres)
JWT_SECRET=ReplaceWithASecureRandomString
# Chave para criptografia (AES-256-GCM) - 32 bytes (base64 ou hex recomendado)
ENCRYPTION_SECRET=ReplaceWith32ByteKeyOrBase64
VAULT_ENCRYPTION_KEY=

# -------------------------------
# API / Frontend
# -------------------------------
API_PORT=8085
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8085

# -------------------------------
# Discord
# -------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_BOT_ENABLED=false

# -------------------------------
# Financeiro / SMTP
# -------------------------------
APP_FINANCEIRO_TEST_MODE=true
APP_FINANCEIRO_DEV_EMAIL=
APP_FINANCEIRO_SMTP_FROM_EMAIL=no-reply@inovare.med.br
APP_FINANCEIRO_SMTP_FROM_NAME=Inovare TI Financeiro

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# -------------------------------
# ContaAzul OAuth2 / Pagamentos
# -------------------------------
CONTAAZUL_CLIENT_ID=
CONTAAZUL_CLIENT_SECRET=
CONTAAZUL_AUTHORIZATION_URL=https://auth.contaazul.com/oauth2/authorize
CONTAAZUL_REDIRECT_URI=http://localhost:5173/contaazul/callback
CONTAAZUL_TOKEN_URL=https://auth.contaazul.com/oauth2/token
CONTAAZUL_PAYMENTS_URL=https://api-v2.contaazul.com/v1/financeiro/eventos-financeiros/contas-a-receber/buscar
CONTAAZUL_RECEIPT_PDF_URL_TEMPLATE=https://api-v2.contaazul.com/v1/pagamentos/{parcelaId}/recibo.pdf

# -------------------------------
# Automação ContaAzul
# -------------------------------
CONTAAZUL_AUTOMATION_ENABLED=false
# Intervalo entre execuções em milissegundos (padrão 5 minutos)
CONTAAZUL_AUTOMATION_FIXED_DELAY_MS=300000
# Delay inicial antes da primeira execução (ms)
CONTAAZUL_AUTOMATION_INITIAL_DELAY_MS=180000

# -------------------------------
# Brevo / serviços de email externos
# -------------------------------
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Inovare TI
BREVO_API_KEY=

# -------------------------------
# Feature toggles e misc
# -------------------------------
APP_SEEDER_ENABLED=true
APP_DEBUG=true
