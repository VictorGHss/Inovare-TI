# -------------------------------
# Banco de dados
# -------------------------------
POSTGRES_DB=inovareti
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_URL=jdbc:postgresql://localhost:5436/inovareti

# -------------------------------
# Segurança e criptografia
# -------------------------------
JWT_SECRET=
ENCRYPTION_SECRET=
VAULT_ENCRYPTION_KEY=

# -------------------------------
# API / Frontend
# -------------------------------
API_PORT=8085
FRONTEND_URL=http://localhost:5173

# -------------------------------
# Discord
# -------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_BOT_ENABLED=false

# -------------------------------
# Financeiro / SMTP
# -------------------------------
APP_FINANCEIRO_TEST_MODE=true
APP_FINANCEIRO_DEV_EMAIL=
APP_FINANCEIRO_SMTP_FROM_EMAIL=
APP_FINANCEIRO_SMTP_FROM_NAME=Inovare TI Financeiro

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# -------------------------------
# ContaAzul OAuth2 / Pagamentos
# -------------------------------
CONTAAZUL_CLIENT_ID=
CONTAAZUL_CLIENT_SECRET=
CONTAAZUL_AUTHORIZATION_URL=https://auth.contaazul.com/oauth2/authorize
CONTAAZUL_TOKEN_URL=https://auth.contaazul.com/oauth2/token
CONTAAZUL_PAYMENTS_URL=https://api.contaazul.com/v1/pagamentos
CONTAAZUL_RECEIPT_PDF_URL_TEMPLATE=https://api.contaazul.com/v1/pagamentos/{parcelaId}/recibo.pdf

# -------------------------------
# Compatibilidade legada
# -------------------------------
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Inovare TI
