# Example .env - NÃO comitar nem colocar segredos em VCS
# Preencha com valores reais no ambiente ou no secrets manager.

# --- DATABASE CONFIG ---
POSTGRES_DB=inovareti
POSTGRES_USER=inovareti_user
POSTGRES_PASSWORD=change_me_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- SECURITY & SECRETS ---
JWT_SECRET=change_this_jwt_secret_base64
ENCRYPTION_SECRET=change_encryption_secret
VAULT_ENCRYPTION_KEY=change_vault_key

# --- INFRA CONFIG ---
API_PORT=8085
# URL pública do frontend (ok se rodando via Cloudflare)
FRONTEND_URL=https://itsm-inovare.ctrls.dev.br
# Opcional (útil localmente)
BACKEND_URL=http://localhost:8085
FILE_UPLOAD_DIR=/mnt/storage/uploads/

# --- DISCORD INTEGRATION ---
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_BOT_ENABLED=false

# --- APPOINTMENT SECRETARY NOTIFICATIONS ---
APP_NOTIFICATION_DISCORD_WEBHOOK=
APP_NOTIFICATION_ITSM_BOT_API_URL=
APP_NOTIFICATION_ITSM_BOT_API_TOKEN=

# --- EMAIL & SMTP (Skymail) ---
APP_FINANCEIRO_TEST_MODE=true
APP_FINANCEIRO_DEV_EMAIL=dev@example.com
APP_FINANCEIRO_SMTP_FROM_EMAIL=administrativo@inovare.med.br
APP_FINANCEIRO_SMTP_FROM_NAME=Administrativo Inovare

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=administrativo@inovare.med.br
SMTP_PASSWORD=change_smtp_password
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# --- BREVO (Fallback) ---
BREVO_SENDER_EMAIL=administrativo@inovare.med.br
BREVO_SENDER_NAME=Inovare TI
BREVO_API_KEY=

# --- CONTA AZUL OAUTH2 / Pagamentos ---
CONTAAZUL_CLIENT_ID=
CONTAAZUL_CLIENT_SECRET=
CONTAAZUL_AUTHORIZATION_URL=https://auth.contaazul.com/oauth2/authorize
CONTAAZUL_REDIRECT_URI=https://itsm-inovare.ctrls.dev.br/api/financeiro/contaazul/callback
CONTAAZUL_TOKEN_URL=https://auth.contaazul.com/oauth2/token
CONTAAZUL_API_V2_BASE_URL=https://api-v2.contaazul.com
CONTAAZUL_PAYMENTS_URL=${CONTAAZUL_API_V2_BASE_URL}/v1/financeiro/eventos-financeiros/contas-a-receber/buscar
CONTAAZUL_BAIXA_DETAILS_URL=${CONTAAZUL_API_V2_BASE_URL}/v1/financeiro/eventos-financeiros/parcelas/baixa
CONTAAZUL_SALES_V2_URL=${CONTAAZUL_API_V2_BASE_URL}/v1/venda/busca
CONTAAZUL_SALE_PDF_V1_URL_TEMPLATE=${CONTAAZUL_API_V2_BASE_URL}/v1/venda/{id}/imprimir

# --- APPOINTMENT MOTOR / BLIP ---
APP_APPOINTMENT_BLIP_BOT_KEY=
APP_APPOINTMENT_BLIP_AGENDAMENTO_BOT_ID=inovare_confirmacao@msging.net
# Alias opcional para configuração via app.blip.bot-identity.
APP_BLIP_BOT_IDENTITY=inovare_confirmacao@msging.net
APP_APPOINTMENT_BLIP_BUILDER_BOT_ID=

# --- AUTOMATION & POLLING ---
CONTAAZUL_AUTOMATION_ENABLED=true
CONTAAZUL_AUTOMATION_FIXED_DELAY_MS=300000
CONTAAZUL_AUTOMATION_INITIAL_DELAY_MS=10000
APP_FINANCEIRO_POLLING_ENABLED=true

# --- RESILIENCE (Redis) ---
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# --- FRONTEND (Vite) - usado no build/runtime do front
VITE_API_URL=https://itsm-inovare.ctrls.dev.br

# Observações:
# - Não use aspas em valores no arquivo .env (o Docker Compose `env_file` preserva as aspas no valor).
# - O backend atualmente tem `app.frontend.url` hard-coded em [api/src/main/resources/application.properties](api/src/main/resources/application.properties).
#   Se quiser que o backend leia `FRONTEND_URL`, altere para: app.frontend.url=${FRONTEND_URL}
# - O docker-compose define um override para `DB_URL` em [docker-compose.yml](docker-compose.yml) (está ok, mas mantenha consistência).
# - NÃO comitar este arquivo com segredos; use um secrets manager em produção.
