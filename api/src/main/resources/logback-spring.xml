<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{traceId}] - %msg%n" />

    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />

    <logger name="br.dev.ctrls.inovareti.modules.appointment.infrastructure.adapter.input.rest" level="WARN" />
    <logger name="br.dev.ctrls.inovareti.modules.appointment.infrastructure.adapter.output.blip" level="WARN" />
    <logger name="br.dev.ctrls.inovareti.modules.appointment.domain" level="DEBUG" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
